apiVersion: 1

datasources:
  - name: Linear
    type: yesoreyeram-linear-datasource
    access: proxy
    jsonData:
      baseURL: https://api.linear.app/graphql
      # Authentication method: "apiKey" (personal API key) or "oauth" (Bearer token).
      authMethod: apiKey
    secureJsonData:
      # Linear personal API key (used when authMethod is apiKey), sent raw as the
      # Authorization header. Create one at:
      #   Settings > Security & access > Personal API keys
      apiKey: ${LINEAR_API_KEY}
      # For OAuth, set authMethod to "oauth" and provide the access token instead:
      # oauthToken: ${LINEAR_OAUTH_TOKEN}
    editable: true
