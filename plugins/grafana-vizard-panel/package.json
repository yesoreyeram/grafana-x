  "dependencies": {
    "@emotion/css": "11.13.5",
    "@grafana/data": "11.6.15",
    "@grafana/ui": "11.6.15",
    "react": "18.3.1",
    "react-dom": "18.3.1",
    "tslib": "2.8.1",
    "vega": "6.2.0",
    "vega-embed": "7.1.0",
    "vega-lite": "6.4.3"
  },
  "engines": {
    "node": ">=24.16.0"
