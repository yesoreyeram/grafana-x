{
  "name": "yesoreyeram-vizard-panel",
  "version": "0.1.0",
  "description": "Grafana panel plugin: a Vega-Lite visual builder that renders any data frame",
  "scripts": {
    "build": "webpack -c ./webpack.config.ts --env production",
    "dev": "webpack -w -c ./webpack.config.ts --env development",
    "typecheck": "tsc --noEmit",
    "spellcheck": "cspell -c cspell.config.json \"**/*.{ts,tsx,js,md,mdx,yml,yaml,json,scss,css}\"",
    "lint": "eslint --cache .",
    "lint:fix": "yarn lint --fix",
    "test": "jest --passWithNoTests"
  },
  "author": "yesoreyeram",
  "license": "Apache-2.0",
  "devDependencies": {
    "@grafana/eslint-config": "9.0.0",
    "@grafana/tsconfig": "2.2.0",
    "@stylistic/eslint-plugin-ts": "4.4.1",
    "@swc/core": "1.15.41",
    "@swc/helpers": "0.5.23",
    "@swc/jest": "0.2.39",
    "@testing-library/dom": "10.4.1",
    "@testing-library/jest-dom": "6.9.1",
    "@testing-library/react": "16.3.2",
    "@types/jest": "29.5.14",
    "@types/lodash": "4.17.24",
    "@types/node": "20.19.43",
    "@types/react": "18.3.31",
    "@types/react-dom": "18.3.7",
    "@typescript-eslint/eslint-plugin": "8.60.1",
    "@typescript-eslint/parser": "8.60.1",
    "copy-webpack-plugin": "12.0.2",
    "cspell": "10.0.1",
    "eslint": "9.39.4",
    "eslint-config-prettier": "10.1.8",
    "eslint-plugin-jsdoc": "63.0.1",
    "eslint-plugin-prettier": "5.5.6",
    "eslint-plugin-react": "7.37.5",
    "eslint-plugin-react-hooks": "7.1.1",
    "eslint-webpack-plugin": "6.0.0",
    "fork-ts-checker-webpack-plugin": "9.1.0",
    "glob": "10.5.0",
    "identity-obj-proxy": "3.0.0",
    "jest": "29.7.0",
    "jest-environment-jsdom": "29.7.0",
    "prettier": "3.8.3",
    "replace-in-file-webpack-plugin": "1.0.6",
    "sass": "1.101.0",
    "sass-loader": "14.2.1",
    "style-loader": "3.3.4",
    "swc-loader": "0.2.7",
