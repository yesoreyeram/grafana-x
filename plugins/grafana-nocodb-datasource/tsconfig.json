{
  "extends": "@grafana/tsconfig",
  "compilerOptions": {
    "rootDir": "./src",
    "baseUrl": "./src",
    "typeRoots": ["./node_modules/@types"]
  },
  "include": ["src", "types"],
  "exclude": ["**/*.test.ts", "**/*.test.tsx", "node_modules", "dist"],
  "ts-node": {
    "compilerOptions": {
      "module": "CommonJS"
    }
  }
}
