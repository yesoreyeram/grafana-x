apiVersion: 1

datasources:
  - name: Strapi
    type: yesoreyeram-strapi-datasource
    access: proxy
    jsonData:
      baseURL: https://your-strapi.example.com
      # Strapi major version: "v5" (default) or "v4".
      apiVersion: v5
      # Optional: plural API id used to validate the token during health checks.
      # defaultContentTypeId: articles
    secureJsonData:
      apiToken: ${STRAPI_API_TOKEN}
    editable: true
