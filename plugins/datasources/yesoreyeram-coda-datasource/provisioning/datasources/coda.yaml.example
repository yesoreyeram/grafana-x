apiVersion: 1

datasources:
  - name: Airtable
    type: yesoreyeram-airtable-datasource
    access: proxy
    jsonData:
      # Optional; defaults to https://api.airtable.com. Only change for a proxy.
      baseURL: https://api.airtable.com
      # Optional default base id (app...). When set, the query editor lists this
      # base's tables directly. Otherwise pick a base in the query editor.
      baseId: appXXXXXXXXXXXXXX
    secureJsonData:
      # Airtable personal access token (PAT). Create one at
      # https://airtable.com/create/tokens with the scopes:
      #   data.records:read, schema.bases:read
      apiToken: ${AIRTABLE_API_TOKEN}
    editable: true
