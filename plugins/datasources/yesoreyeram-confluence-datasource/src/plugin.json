    ],
    "logos": {
      "small": "img/logo.svg",
      "large": "img/logo.svg"
    },
    "links": [
      {
        "name": "Website",
        "url": "https://github.com/yesoreyeram/grafana-x"
      },
      {
        "name": "Confluence REST API",
