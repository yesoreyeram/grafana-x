{
  "name": "@yesoreyeram/grafana-vizard-panel",
  "version": "0.1.0",
  "description": "Grafana panel plugin: a Vega-Lite visual builder that renders any data frame",
  "scripts": {
    "build": "webpack -c ./webpack.config.ts --env production",
    "dev": "webpack -w -c ./webpack.config.ts --env development",
    "typecheck": "tsc --noEmit",
    "spellcheck": "cspell -c cspell.config.json \"**/*.{ts,tsx,js,md,mdx,yml,yaml,json,scss,css}\"",
    "lint": "eslint --cache .",
    "lint:fix": "yarn lint --fix",
    "test": "jest --passWithNoTests"
  },
  "author": "yesoreyeram",
  "license": "Apache-2.0",
  "devDependencies": {
