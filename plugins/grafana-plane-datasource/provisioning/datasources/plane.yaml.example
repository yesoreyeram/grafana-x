apiVersion: 1

datasources:
  - name: Plane
    type: yesoreyeram-plane-datasource
    access: proxy
    jsonData:
      baseURL: https://api.plane.so
      # Default workspace slug (the unique identifier from the Plane URL, e.g.
      # the "my-team" in https://app.plane.so/my-team/projects/). Optional; a
      # query can override it.
      workspaceSlug: ${PLANE_WORKSPACE_SLUG}
      # Authentication method: "apiKey" (X-API-Key) or "oauth" (Bearer token).
      authMethod: apiKey
    secureJsonData:
      # Plane personal API key (used when authMethod is apiKey), sent as the
      # X-API-Key header. Generate one at:
      #   Profile Settings > Personal Access Tokens
      apiKey: ${PLANE_API_KEY}
      # For OAuth, set authMethod to "oauth" and provide the access token instead:
      # oauthToken: ${PLANE_OAUTH_TOKEN}
    editable: true
