# Dependencies
node_modules/

# Yarn 4 (Berry) — keep releases/plugins/patches/sdks/versions, ignore the rest
# https://yarnpkg.com/getting-started/qa#which-files-should-be-gitignored
.yarn/*
!.yarn/patches
!.yarn/plugins
!.yarn/releases
!.yarn/sdks
!.yarn/versions
.yarn/install-state.gz
.yarn/build-state.yml
.pnp.*

# Build output
dist/
build/
out/
coverage/
*.tsbuildinfo

# Test artifacts
playwright-report/
test-results/
.nyc_output/

# Logs
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*
lerna-debug.log*

# Environment / secrets
.env
.env.*
!.env.example

# OS
.DS_Store
Thumbs.db

# Editors / IDEs
.vscode/
!.vscode/extensions.json
!.vscode/settings.json.example
.idea/
*.swp
*.swo
*~

# Misc
.cache/
.turbo/
.parcel-cache/
