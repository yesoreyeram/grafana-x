{
  "name": "@yesoreyeram/grafana-x",
  "version": "0.0.1",
  "private": true,
  "description": "Collection of grafana plugins, datasources, panels, tools, components, libraries, utils, etc",
  "keywords": [
    "grafana"
  ],
  "author": {
    "name": "Sriramajeyam Sugumaran",
    "url": "https://x.com/yesoreyeram"
  },
  "license": "Apache-2.0",
  "homepage": "https://github.com/yesoreyeram/grafana-x#readme",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/yesoreyeram/grafana-x.git"
  },
  "bugs": {
    "url": "https://github.com/yesoreyeram/grafana-x/issues"
  },
  "workspaces": [
    "packages/*",
    "plugins/datasources/*",
    "plugins/panel/*",
    "plugins/app/*"
  ],
  "scripts": {
    "build": "turbo run build",
    "typecheck": "turbo run typecheck",
    "test": "turbo run test",
    "lint": "eslint .",
    "lint:fix": "eslint . --fix",
    "format": "prettier --write \"packages/**/src/**/*.ts\"",
    "format:check": "prettier --check \"packages/**/src/**/*.ts\"",
    "spellcheck": "cspell -c cspell.config.json \"**/*.{ts,tsx,js,go,md,mdx,yml,yaml,json,scss,css}\"",
    "changeset": "changeset",
    "version-packages": "changeset version",
    "release": "turbo run build && changeset publish"
  },
  "devDependencies": {
    "@changesets/cli": "catalog:",
    "@eslint/js": "catalog:",
    "cspell": "catalog:",
    "eslint": "catalog:",
    "prettier": "catalog:",
    "turbo": "catalog:",
    "typescript": "catalog:",
    "typescript-eslint": "catalog:"
  },
  "resolutions": {
    "@opentelemetry/core": "^2.8.0",
    "dompurify": "^3.4.11",
    "js-cookie": "^3.0.8",
    "esbuild": "^0.28.1",
    "serialize-javascript": "^7.0.5",
    "undici": "^6.27.0",
    "uuid": "^11.1.1",
    "js-yaml": "^4.1.0",
    "glob": "^11.0.0",
    "raw-body": "^2.5.2",
    "node-gyp": "^13.0.0"
  },
  "engines": {
    "node": ">=24.16.0",
    "yarn": ">=4.16.0"
  },
  "packageManager": "yarn@4.16.0"
}
