{
  "$schema": "https://turborepo.com/schema.json",
  "ui": "stream",
  "globalDependencies": [
    ".nvmrc",
    "cspell.config.json",
    "eslint.config.mjs"
  ],
  "globalEnv": [
    "CI",
    "NODE_ENV"
  ],
  "tasks": {
    "build": {
      "description": "Build a Grafana plugin: webpack frontend + copied assets (dist/module.js, plugin.json, README, LICENSE, img) and Go backend binaries (dist/gpx_*, go_plugin_build_manifest).",
      "dependsOn": [
        "^build"
      ],
      "inputs": [
        "$TURBO_DEFAULT$"
      ],
      "outputs": [
        "dist/**"
      ]
    },
    "typecheck": {
      "description": "Type-check frontend sources with tsc; emits no cacheable file output.",
      "dependsOn": [
        "^build"
      ],
      "inputs": [
        "$TURBO_DEFAULT$"
      ],
      "outputs": []
    },
    "test": {
      "description": "Run unit tests (frontend Jest + Go backend); emits no cacheable file output.",
      "dependsOn": [
        "^build"
      ],
      "inputs": [
        "$TURBO_DEFAULT$"
      ],
      "outputs": []
    },
    "lint": {
      "inputs": [
        "$TURBO_DEFAULT$"
      ],
      "outputs": [
        ".eslintcache"
      ]
    },
    "spellcheck": {
      "inputs": [
        "$TURBO_DEFAULT$"
      ],
      "outputs": []
    },
    "dev": {
      "cache": false,
      "persistent": true
    },
    "clean": {
      "cache": false
    }
  }
}
