{
  "name": "@yesoreyeram/grafana-utils",
  "version": "0.0.1",
  "description": "CLI tool for grafana dev and management utils",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "bin": "dist/cli.js",
  "type": "module",
  "files": [
    "dist",
    "README.md",
    "LICENSE"
  ],
  "publishConfig": {
    "access": "public"
  },
  "keywords": [
    "grafana",
    "datasource",
    "cli",
    "utility"
  ],
  "author": {
    "name": "Sriramajeyam Sugumaran",
    "url": "https://x.com/yesoreyeram"
  },
  "license": "Apache-2.0",
  "homepage": "https://github.com/yesoreyeram/grafana-x#readme",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/yesoreyeram/grafana-x.git"
  },
  "bugs": {
    "url": "https://github.com/yesoreyeram/grafana-x/issues"
  },
  "scripts": {
    "clean": "node --eval \"require('node:fs').rmSync('dist',{recursive:true,force:true})\"",
    "build": "yarn clean && tsc --project tsconfig.build.json",
    "dev": "tsx src/cli.ts",
    "typecheck": "tsc --noEmit",
    "test": "tsx --test \"src/**/*.test.ts\"",
    "prepublishOnly": "yarn build"
  },
  "dependencies": {
    "commander": "^12.1.0"
  },
  "devDependencies": {
    "@types/node": "25.9.1",
    "tsx": "^4.19.0",
    "typescript": "6.0.3"
  },
  "engines": {
    "node": ">=24.16.0"
  },
  "packageManager": "yarn@4.16.0"
}
