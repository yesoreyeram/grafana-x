# Limits the ability for npm to fetch dependencies from git references. 
# set to all/ignore this when using older version of @grafana/ui packages which depends on git version react-grid depdenency
allow-git=none

# Run security audit on every install. audit-level is intentionally not set:
# Renovate's vulnerability alerts already surface high/critical issues via
# dedicated PRs (schedule: at any time, bypassing minimumReleaseAge).
audit=true

# npm will stubbornly refuse to install (or even consider installing) any package that claims to not be compatible with the current Node.js version.
engine-strict=true

# Suppress funding messages (reduces noise)
fund=false

# Block post-install scripts from running
ignore-scripts=true

# Enforce a 3-day cooldown before newly-published packages can be installed.
# Matches Renovate's minimumReleaseAge window.
# Requires npm >=11.13 (min-release-age config support).
min-release-age=3

# The base URL of the npm registry.
registry=https://registry.npmjs.org/

# Save exact versions on npm install (no ^ or ~ ranges)
save-exact=true

# Enforce SSL verification for all registry connections
strict-ssl=true
