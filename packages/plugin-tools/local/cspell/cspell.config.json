{
    "$schema": "https://raw.githubusercontent.com/streetsidesoftware/cspell/refs/heads/main/cspell.schema.json",
    "language": "en",
    "ignorePaths": [
        ".config/**",
        ".github/**",
        "*_test.go",
        "*.{spec,test}.{ts,tsx}",
        "coverage/**",
        "dist/**",
        "docker-compose*.{yml,yaml}",
        "docker/blocks/**",
        "jest*.js",
        "renovate.json",
        "node_modules/**",
        "package.json",
        "provisioning/**",
        "renovate.json",
        "src/dashboards/**",
    ],
    "ignoreRegExpList": [
        "import\\s*\\((.|[\r\n])*?\\)",
        "import\\s*.*\".*?\""
    ],
    "dictionaries": [
        "grafana",
        "plugin"
    ],
    "dictionaryDefinitions": [
        {
            "name": "grafana",
            "path": "./.cspell/grafana.txt"
        },
        {
            "name": "plugin",
            "path": "./.cspell/plugin.txt"
        }
    ],
    "words": []
}
